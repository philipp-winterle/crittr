{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "strict": true,
        "esModuleInterop": true,
        "allowJs": true,
        "checkJs": false,
        "declaration": true,
        "declarationMap": false,
        "sourceMap": true,
        "outDir": "dist",
        "rootDir": ".",
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "types": ["node"]
    },
    "include": ["index.ts", "lib/**/*.ts", "lib/types/**/*.d.ts"],
    "exclude": ["node_modules", "dist", "test", "examples", "_workspace", "lib/evaluation/**"]
}
